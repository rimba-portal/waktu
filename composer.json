{
    "name": "rimba/waktu",
    "description": "Handles time structures like holidays, shifts, rosters, and events.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "rimba/asas": "^1.0",
        "rimba/orang": "^1.0",
        "rimba/pihak": "^1.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rimba\\Time\\TimeServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
           "Rimba\\Time\\": "src/"
        }
    },
    "minimum-stability": "alpha",
    "prefer-stable": true
}
